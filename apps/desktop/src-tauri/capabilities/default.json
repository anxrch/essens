{
  "identifier": "default",
  "description": "Default capabilities for essens",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "name": "binaries/essens-sidecar",
          "sidecar": true
        }
      ]
    }
  ]
}
